# Variáveis lidas pelo docker compose (dev e prod).
# Copie para `.env` na raiz e ajuste. Todos têm defaults sensatos para DEV,
# então em desenvolvimento o `.env` é opcional. Em PRODUÇÃO, preencha tudo.
#
# Segredos específicos da API (ANTHROPIC_API_KEY, RESEND_API_KEY, etc.) também
# podem ficar em apps/api/.env em dev — o compose de dev carrega esse arquivo.
# Em produção, use ESTE arquivo (.env na raiz). Runbook: docs/deploy.md

# ── Seed (dev) ──────────────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@codinhos.com.br
SEED_SUPER_ADMIN_PASSWORD=Admin123!codinhos

# ── Sessão / IA / e-mail ────────────────────────────────────────────────────
# Gere um segredo forte: openssl rand -base64 48
SESSION_SECRET=troque-por-uma-string-aleatoria-de-no-minimo-32-caracteres
SESSION_TTL_SECONDS=604800
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
EMAIL_FROM=noreply@codinhos.com.br
RESEND_API_KEY=
CONTACT_TO=contato@codinhos.com.br

# ══ PRODUÇÃO (docker-compose.prod.yml) ══════════════════════════════════════

# ── Domínio e TLS ───────────────────────────────────────────────────────────
# O Caddy emite certificados Let's Encrypt automaticamente para estes hosts.
# Aponte no DNS (Registro.br): A @ e A app → IP do servidor; www → apex.
DOMAIN=codinhos.com.br
APP_DOMAIN=app.codinhos.com.br
ACME_EMAIL=admin@codinhos.com.br

# ── Banco ───────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
# A senha entra crua na DATABASE_URL — use só letras/números/-/_ (evite @ : / # &
# ? e espaços) para não precisar de URL-encoding. Ex.: openssl rand -hex 24
POSTGRES_PASSWORD=troque-por-uma-senha-forte-em-producao
POSTGRES_DB=codinhos

# ── Backup do Postgres ──────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
BACKUP_CRON=0 3 * * *

# ── URLs públicas (derivadas do domínio; sobrescreva só se precisar) ─────────
# API embutida no bundle do SPA em build time (mesmo host do SPA → sem CORS).
VITE_API_URL=https://app.codinhos.com.br
# API usada pela landing (mesmo host da LP → sem CORS).
NEXT_PUBLIC_API_URL=https://codinhos.com.br
NEXT_PUBLIC_APP_URL=https://app.codinhos.com.br
NEXT_PUBLIC_SITE_URL=https://codinhos.com.br
# Origens permitidas no CORS da API (redundante no single-origin, mas explícito).
CORS_ORIGIN=https://codinhos.com.br,https://app.codinhos.com.br
# Link usado em e-mails (convites, reset de senha).
APP_URL=https://app.codinhos.com.br
# Cookie de sessão é host-only por padrão (mais seguro). Só preencha
# (ex.: .codinhos.com.br) se precisar compartilhar sessão entre subdomínios.
COOKIE_DOMAIN=

# ── Google Classroom (rostering) ────────────────────────────────────────────
# Crie o OAuth Client (Web) no Google Cloud Console e registre o redirect URI
# EXATAMENTE como abaixo. Ver docs/deploy.md.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://app.codinhos.com.br/api/integrations/google/callback
