# Variáveis lidas pelo docker compose (dev e prod).
# Copie para `.env` na raiz e ajuste. Todos têm defaults sensatos para DEV,
# então em desenvolvimento o `.env` é opcional.
#
# Segredos específicos da API (ANTHROPIC_API_KEY, RESEND_API_KEY, etc.) podem
# ficar em apps/api/.env — o compose carrega esse arquivo automaticamente.

# ── Seed (dev) ──────────────────────────────────────────────────────────────
SEED_SUPER_ADMIN_EMAIL=admin@codinhos.com.br
SEED_SUPER_ADMIN_PASSWORD=Admin123!codinhos

# ── Sessão / IA / e-mail ────────────────────────────────────────────────────
SESSION_SECRET=troque-por-uma-string-aleatoria-de-no-minimo-32-caracteres
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
EMAIL_FROM=noreply@codinhos.com.br
RESEND_API_KEY=

# ── Produção (docker-compose.prod.yml) ──────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-em-producao
POSTGRES_DB=codinhos
# URL pública da API embutida no bundle do app (SPA) em build time
VITE_API_URL=http://localhost:3333
# Origens permitidas no CORS da API (web e app)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
APP_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:8080
