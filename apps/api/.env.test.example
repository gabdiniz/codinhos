# Banco de dados de TESTE — nunca use o banco de desenvolvimento aqui
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codinhos_test

# Sessão (pode ser qualquer string em testes)
SESSION_SECRET=test-secret-nao-usar-em-producao
SESSION_TTL_SECONDS=604800

# IA (não é usada nos testes — pode ser string qualquer)
ANTHROPIC_API_KEY=sk-ant-test-key

# Ambiente
NODE_ENV=test
PORT=3334

# Email (não envia em testes)
EMAIL_FROM=test@codinhos.com.br
RESEND_API_KEY=re_test_key
