# Banco de dados
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codinhos

# Sessão
SESSION_SECRET=troque-por-string-aleatoria-segura-minimo-32-chars
SESSION_TTL_SECONDS=604800

# IA
ANTHROPIC_API_KEY=sk-ant-substitua-pela-sua-chave
AI_MODEL=claude-haiku-4-5-20251001

# Servidor
NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
COOKIE_DOMAIN=

# Email
EMAIL_FROM=noreply@codinhos.com.br
RESEND_API_KEY=re_substitua-pela-sua-chave

# Frontend (usado em links de e-mail)
APP_URL=http://localhost:3000

# Seed (usado apenas pelo script db:seed)
SEED_SUPER_ADMIN_EMAIL=admin@codinhos.com.br
SEED_SUPER_ADMIN_PASSWORD=troque-antes-de-rodar

# Integração Google Classroom (Sprint 6 — rostering one-way)
# Crie um OAuth Client (tipo Web) no Google Cloud Console, habilite a Classroom API
# e registre o redirect URI exatamente como abaixo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3333/api/integrations/google/callback
