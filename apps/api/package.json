{
  "name": "@codinhos/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "biome lint ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:test": "tsx scripts/migrate-test.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/shared/db/seed.ts",
    "db:seed:trilha": "tsx src/shared/db/seed-trilha-js.ts",
    "db:seed:recursao": "tsx src/shared/db/seed-trilha-recursao.ts",
    "db:seed:console": "tsx src/shared/db/seed-trilha-console.ts",
    "db:seed:p5": "tsx src/shared/db/seed-trilha-p5.ts",
    "db:seed:python-01": "tsx src/shared/db/seed-trilha-python-01.ts",
    "db:seed:python-02": "tsx src/shared/db/seed-trilha-python-02.ts",
    "db:seed:python-03": "tsx src/shared/db/seed-trilha-python-03.ts",
    "db:seed:python-04": "tsx src/shared/db/seed-trilha-python-04.ts",
    "db:seed:python-05": "tsx src/shared/db/seed-trilha-python-05.ts",
    "db:seed:python-06": "tsx src/shared/db/seed-trilha-python-06.ts",
    "db:seed:python-07": "tsx src/shared/db/seed-trilha-python-07.ts",
    "db:seed:python-08": "tsx src/shared/db/seed-trilha-python-08.ts",
    "db:seed:python-09": "tsx src/shared/db/seed-trilha-python-09.ts",
    "db:seed:python-10": "tsx src/shared/db/seed-trilha-python-10.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "postgres": "^3.4.5",
    "resend": "^4.0.0",
    "zod": "^3.23.8",
    "pdfkit": "^0.15.1",
    "@codinhos/runner": "workspace:*",
    "@codinhos/runner-python": "workspace:*"
  },
  "devDependencies": {
    "@codinhos/types": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "@types/pdfkit": "^0.13.5"
  }
